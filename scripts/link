#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/CaseMark/casedev-go,github.com/stainless-sdks/router-go"

REPLACEMENT="${1:-"../casedev-go"}"
echo "==> Replacing Go SDK with $REPLACEMENT"
go mod edit -replace github.com/CaseMark/casedev-go="$REPLACEMENT"
go mod tidy -e
